# Mythese — Variables d'environnement
# REMPLIR ce fichier avant 23h ce soir, puis renommer en .env.local
# Toutes les clés sont nécessaires pour que le code de la nuit fonctionne.

# --- Supabase (DB + Auth) ---
# Sur supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude API) ---
# Sur console.anthropic.com > API Keys (provisionner 50€ de crédit)
ANTHROPIC_API_KEY=

# --- Resend (emails transactionnels) ---
# Sur resend.com > API Keys (vérifier mythese.com avant)
RESEND_API_KEY=

# --- OpenAlex (recherche scientifique, no API key) ---
# Pas de clé, juste un email pour user-agent politeness
OPENALEX_EMAIL=mesconvictionsia@gmail.com

# --- Site config ---
NEXT_PUBLIC_SITE_URL=https://mythese.com
NEXT_PUBLIC_APP_URL=https://app.mythese.com
